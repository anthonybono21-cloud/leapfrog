{
  "name": "leapfrog",
  "version": "0.3.0",
  "description": "Multi-session browser MCP for AI agents — 21 tools, up to 10x fewer tokens than Playwright, stealth mode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/types.d.ts",
  "bin": {
    "leapfrog": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/__tests__",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": [
    "mcp",
    "browser",
    "headless",
    "playwright",
    "ai-agent",
    "automation",
    "web-scraping",
    "multi-session",
    "stealth",
    "dom-snapshot",
    "model-context-protocol",
    "claude",
    "cursor",
    "windsurf",
    "browser-automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthonybono21-cloud/leapfrog"
  },
  "homepage": "https://github.com/anthonybono21-cloud/leapfrog#readme",
  "bugs": {
    "url": "https://github.com/anthonybono21-cloud/leapfrog/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "playwright": "^1.59.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
